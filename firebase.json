{
  "hosting": {
    "source": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "frameworksBackend": {
      "region": "us-central1"
    },
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cross-Origin-Opener-Policy",
            "value": "same-origin-allow-popups"
          },
          {
            "key": "Content-Security-Policy",
            "value": "upgrade-insecure-requests"
          },
          {
            "key": "Strict-Transport-Security",
            "value": "max-age=31536000; includeSubDomains"
          }
        ]
      }
    ],
    "rewrites": [
      { "source": "/api/generateWorkout", "function": { "functionId": "generateWorkout", "region": "us-central1" } },
      { "source": "/api/analyzeWorkout", "function": { "functionId": "analyzeWorkout", "region": "us-central1" } },
      { "source": "/api/getSubscription", "function": { "functionId": "getSubscription", "region": "us-central1" } },
      { "source": "/api/subscribe", "function": { "functionId": "subscribe", "region": "us-central1" } },
      { "source": "/api/cancelSubscription", "function": { "functionId": "cancelSubscription", "region": "us-central1" } }
    ]
  },
  "functions": {
    "source": "functions",
    "codebase": "default",
    "runtime": "nodejs22"
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
