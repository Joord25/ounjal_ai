rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // User profile: user can read/write their own profile doc
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Subscriptions: only accessible via admin SDK (Firebase Functions)
      match /subscriptions/{docId} {
        allow read, write: if false;
      }

      // Workout history: user can read/write their own data
      match /workout_history/{historyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 국제 결제 대기명단 (Paddle 심사 통과 전 EN 유저 관심 수집)
    // 본인 doc 만 읽기/쓰기. doc ID = uid
    match /international_waitlist/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
